#include <iostream>
using namespace std;

class Student
{
public:
    int id;
    string name;
    int age;
    float marks;
    string grade;

    Student() {}

    Student(int sid, string sname, int sage, float smarks)
    {
        id = sid;
        name = sname;
        age = sage;
        marks = smarks;
        calculateGrade();
    }

    void calculateGrade()
    {
        if(marks >= 85)
            grade = "Excellent";
        else if(marks >= 70)
            grade = "Good";
        else if(marks >= 50)
            grade = "Average";
        else
            grade = "Improve";
    }

    void display()
    {
        cout << "\n--- Student Profile ---" << endl;
        cout << "ID     : " << id << endl;
        cout << "Name   : " << name << endl;
        cout << "Age    : " << age << endl;
        cout << "Marks  : " << marks << endl;
        cout << "Performance : " << grade << endl;
    }
};

int main()
{
    int n;
    cout << "Enter number of students: ";
    cin >> n;

    Student s[n];

    for(int i = 0; i < n; i++)
    {
        int id, age;
        string name;
        float marks;

        cout << "\nEnter details of Student " << i+1 << endl;

        cout << "ID: ";
        cin >> id;

        cout << "Name: ";
        cin >> name;

        cout << "Age: ";
        cin >> age;

        cout << "Marks: ";
        cin >> marks;

        s[i] = Student(id, name, age, marks);
    }

    cout << "\n===== Student Records =====";

    for(int i = 0; i < n; i++)
    {
        s[i].display();
    }

    return 0;
}
