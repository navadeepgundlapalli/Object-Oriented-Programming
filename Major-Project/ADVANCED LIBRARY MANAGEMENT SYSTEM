struct Date
{
    int day, month, year;

    void input()
    {
        char s1,s2;
        cout<<"Enter date (dd/mm/yyyy): ";
        cin>>day>>s1>>month>>s2>>year;
    }

    void display()
    {
        cout<<day<<"/"<<month<<"/"<<year;
    }

    int toDays()
    {
        return year*365 + month*30 + day;
    }
};

