#include<iostream>
using namespace std;

class shape
{
public:
    virtual void draw () = 0; // Pure virtual function
};

class circle : public shape
{
public:
    void draw() override
    {
        cout << "Drawing a circle" << endl;
    }
};  

class rectangle : public shape
{
public:
    void draw() override
    {
        cout << "Drawing a rectangle" << endl;
    }
};  

int main()
{
    shape *shapePtr;
    circle circle1;
    rectangle rectangle1;

    shapePtr = &circle1;
    shapePtr->draw();

    shapePtr = &rectangle1;
    shapePtr->draw();

    return 0;
}
