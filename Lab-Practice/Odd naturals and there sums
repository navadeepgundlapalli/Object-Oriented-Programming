#include<iostream>
using namespace std;

int main(){
    int num, sum = 0;
    cout<<"Enter the number of terms: ";
    cin>>num;
    cout<<"First "<<num<<" odd natural numbers are: ";
    for(int i = 0; i < num; i++){
        int oddnum = 2*i + 1;
        cout<<oddnum<<" ";
        sum += oddnum;
    }
    cout<<"\nsum of these oddnumbers is: "<<sum<<endl;
    return 0;
}
