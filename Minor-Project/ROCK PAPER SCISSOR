#include <iostream>
#include <iomanip>
using namespace std;

string player1, player2;

int score1 = 0;
int score2 = 0;
int draws = 0;

void line()
{
    cout<<"================================================\n";
}

string choiceName(int c)
{
    if(c==1) return "Rock";
    if(c==2) return "Paper";
    if(c==3) return "Scissors";
    return "Invalid";
}

int decideWinner(int p1,int p2)
{
    if(p1==p2)
        return 0;

    if((p1==1 && p2==3) ||
       (p1==2 && p2==1) ||
       (p1==3 && p2==2))
        return 1;

    return -1;
}

void announceWinner()
{
    line();
    cout<<"                FINAL RESULT\n";
    line();

    if(score1 > score2)
    {
        cout<<"\n**************************************\n";
        cout<<"           "<<player1<<" WINS!\n";
        cout<<"**************************************\n";
    }
    else if(score2 > score1)
    {
        cout<<"\n**************************************\n";
        cout<<"           "<<player2<<" WINS!\n";
        cout<<"**************************************\n";
    }
    else
    {
        cout<<"\n**************************************\n";
        cout<<"             GAME DRAW!\n";
        cout<<"**************************************\n";
    }

    cout<<"\nFinal Score -> "<<player1<<": "<<score1
        <<"  "<<player2<<": "<<score2<<endl;

    line();
}

void scoreboard()
{
    line();

    cout<<setw(15)<<"Player"<<setw(10)<<"Score"<<endl;

    line();

    cout<<setw(15)<<player1<<setw(10)<<score1<<endl;
    cout<<setw(15)<<player2<<setw(10)<<score2<<endl;

    line();
}

void statistics()
{
    int total = score1 + score2 + draws;

    float p1p=0,p2p=0;

    if(total>0)
    {
        p1p = (score1*100.0)/total;
        p2p = (score2*100.0)/total;
    }

    line();
    cout<<"GAME STATISTICS\n";
    line();

    cout<<"Total Rounds : "<<total<<endl;
    cout<<player1<<" Wins : "<<score1<<endl;
    cout<<player2<<" Wins : "<<score2<<endl;
    cout<<"Draws : "<<draws<<endl;

    cout<<player1<<" Win % : "<<p1p<<"%\n";
    cout<<player2<<" Win % : "<<p2p<<"%\n";

    line();
}

void resetScores()
{
    score1 = 0;
    score2 = 0;
    draws = 0;
}

void singlePlayerGame()
{
    int playerMove, computerMove;
    int rounds;

    player1 = "Player";
    player2 = "Computer";

    cout<<"Enter number of rounds: ";
    cin>>rounds;

    for(int r=1;r<=rounds;r++)
    {
        cout<<"\nRound "<<r<<"\n";

        cout<<"1 Rock\n2 Paper\n3 Scissors\n";
        cout<<"Enter choice: ";
        cin>>playerMove;

        computerMove = (playerMove + r) % 3 + 1;

        cout<<"You chose "<<choiceName(playerMove)<<endl;
        cout<<"Computer chose "<<choiceName(computerMove)<<endl;

        int result = decideWinner(playerMove,computerMove);

        if(result==1)
        {
            cout<<"You win this round\n";
            score1++;
        }
        else if(result==-1)
        {
            cout<<"Computer wins this round\n";
            score2++;
        }
        else
        {
            cout<<"Round Draw\n";
            draws++;
        }

        cout<<"Score -> You:"<<score1<<" Computer:"<<score2<<endl;
    }

    announceWinner();
}

void multiplayerGame()
{
    int p1,p2;
    int rounds;

    cout<<"Enter Player1 name: ";
    cin>>player1;

    cout<<"Enter Player2 name: ";
    cin>>player2;

    cout<<"Enter number of rounds: ";
    cin>>rounds;

    for(int r=1;r<=rounds;r++)
    {
        cout<<"\nRound "<<r<<"\n";

        cout<<player1<<" choose\n";
        cout<<"1 Rock\n2 Paper\n3 Scissors\n";
        cin>>p1;

        cout<<player2<<" choose\n";
        cout<<"1 Rock\n2 Paper\n3 Scissors\n";
        cin>>p2;

        cout<<player1<<" chose "<<choiceName(p1)<<endl;
        cout<<player2<<" chose "<<choiceName(p2)<<endl;

        int result = decideWinner(p1,p2);

        if(result==1)
        {
            cout<<player1<<" wins this round\n";
            score1++;
        }
        else if(result==-1)
        {
            cout<<player2<<" wins this round\n";
            score2++;
        }
        else
        {
            cout<<"Round Draw\n";
            draws++;
        }

        cout<<"Score -> "<<player1<<":"<<score1
            <<" "<<player2<<":"<<score2<<endl;
    }

    announceWinner();
}

int main()
{
    int choice;

    do
    {
        line();
        cout<<"         ROCK PAPER SCISSORS GAME\n";
        line();

        cout<<"1 Single Player\n";
        cout<<"2 Multiplayer\n";
        cout<<"3 Scoreboard\n";
        cout<<"4 Statistics\n";
        cout<<"5 Reset Scores\n";
        cout<<"6 Exit\n";

        line();

        cout<<"Enter choice: ";
        cin>>choice;

        switch(choice)
        {
            case 1:
                resetScores();
                singlePlayerGame();
                break;

            case 2:
                resetScores();
                multiplayerGame();
                break;

            case 3:
                scoreboard();
                break;

            case 4:
                statistics();
                break;

            case 5:
                resetScores();
                cout<<"Scores reset\n";
                break;

            case 6:
                cout<<"Game Ended\n";
                break;

            default:
                cout<<"Invalid Choice\n";
        }

    }while(choice!=6);

    return 0;
}
